# ApplyTrack — Environment Variables
# Copy to .env and fill in values before starting

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jobtracker:jobtracker_password@db:5432/jobtracker

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# ── Encryption (IMAP passwords at rest) ─────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Email Parsing ────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional: set to enable Ollama fallback (e.g. http://127.0.0.1:11434)
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# ── Payments (Razorpay) ──────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email Forwarding ─────────────────────────────────────
INBOX_DOMAIN=inbox.applytrack.app
WEBHOOK_SECRET=webhook-secret-change-in-production
# Mailgun inbound routing credentials (set after configuring Mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── Transactional Email (password reset / verification) ──
# Uses Mailgun. Set MAILGUN_API_KEY and MAILGUN_DOMAIN above.
EMAIL_FROM=noreply@applytrack.app

# ── Admin ────────────────────────────────────────────────
# Required for admin endpoints (e.g. seed-razorpay-plans)
ADMIN_SECRET=

# ── CORS / Frontend ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000/api/v1
