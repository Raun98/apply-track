# ApplyTrack — Environment Variables
# Copy to .env and fill in values before starting

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jobtracker:jobtracker_password@db:5432/jobtracker

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# ── Encryption (IMAP passwords at rest) ─────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Email Parsing ────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional: set to enable Ollama fallback (e.g. http://127.0.0.1:11434)
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2

# ── Payments (Razorpay) ──────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email Forwarding ─────────────────────────────────────
INBOX_DOMAIN=inbox.applytrack.app
WEBHOOK_SECRET=webhook-secret-change-in-production
# Mailgun inbound routing credentials (set after configuring Mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Mailgun inbound webhook signing key (Mailgun dashboard → Webhooks → HTTP webhook signing key)
# This is DIFFERENT from the API key above.
MAILGUN_WEBHOOK_SIGNING_KEY=

# ── Transactional Email (password reset / verification) ──
# Uses Mailgun. Set MAILGUN_API_KEY and MAILGUN_DOMAIN above.
EMAIL_FROM=noreply@applytrack.app

# ── OAuth2 (Gmail + Outlook) ─────────────────────────────
# Google: create credentials at https://console.cloud.google.com/
# Scopes needed: https://mail.google.com/ email openid
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft: register app at https://portal.azure.com/
# Scopes needed: IMAP.AccessAsUser.All offline_access email openid profile
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Base URL for OAuth callback (your backend public URL, no trailing slash)
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

# ── Admin ────────────────────────────────────────────────
# Required for admin endpoints (e.g. seed-razorpay-plans)
ADMIN_SECRET=

# ── CORS / Frontend ──────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000/api/v1
